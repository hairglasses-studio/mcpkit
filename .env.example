# rdloop secret configuration — uses 1Password op:// references.
# Get item UUIDs via: op item get "Item Name" --vault Personal --format json | jq '.id'
#
# Requires: op CLI installed + authenticated (op signin)
# The rdloop.sh launcher resolves these via `op run --env-file=.env`.
ANTHROPIC_API_KEY=op://Personal/YOUR_ITEM_UUID/password
GITHUB_TOKEN=op://Personal/YOUR_ITEM_UUID/credential
